        <main>
            <div class="content-wrapper">
                <div class="error-content">
                    <div class="emoji">🌐</div>
                    <h1 class="error-title">Website Not Found</h1>
                    <p class="error-description">The website is not registered in the <a href="https://www.ucoz.com/?utm_source=ucoz-error&utm_medium=text-link&utm_campaign=404-1&utm_content=ucoz-mention&utm_lang=en" target="_blank">uCoz</a> website creation system.<br/>
                    If you are sure that your website should definitely be here, <br/>contact our <a href="https://www.ucoz.com/contact?utm_source=ucoz-error&utm_medium=support-link&utm_campaign=404-1&utm_content=support-contact&utm_lang=en" target="_blank">customer support service</a>.<br/>
                    If you were searching for something on the internet and ended up here, try searching again:</p>
                </div>
                <div class="error-code-container">
                    <div class="error-code">404</div>
                </div>
            </div>
        </main>
        
        <footer>
            <div class="search-container">
                <label for="search_word" class="search-label">Search the Internet</label>
                <div id="search">
                    <form action="https://yandex.ru/yandsearch" method="get">
                        <input id="search_word" type="text" class="searchword" name="text">
                        <input type="submit" class="searchsbm" value="Search">
                        <input value="12090474" name="clid" type="hidden">
                    </form>
                    <script>try {document.getElementById('search_word').value = location.href;} catch (e){console.error(e)}</script>
                </div>
                <div class="browser-promo">
                    <div class="browser-promo-text">Searching and working is easier in a smart browser with AI capabilities: <a href="https://browsers.ucoz.ru/en-bro?utm_source=ucoz-error&utm_medium=bottom&utm_campaign=404-1&utm_content=browser-download&utm_lang=en" target="_blank">download browser with AI now</a></div>
                </div>
            </div>
        </footer>
        
        <!-- Yandex.Metrika counter -->
